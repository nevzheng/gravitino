FROM eclipse-temurin:17.0.16_8-jdk-jammy

RUN apt-get update \
    && apt-get install --yes --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/* \
    && useradd --uid 1000 --gid 0 --create-home --shell /bin/bash gravitino

WORKDIR /opt/gravitino-iceberg-rest-server

COPY --chown=1000:0 build/iceberg-rest/ /opt/gravitino-iceberg-rest-server/
COPY --chown=1000:0 iceberg-rest-server.conf \
    /opt/gravitino-iceberg-rest-server/conf/gravitino-iceberg-rest-server.conf

RUN chmod +x /opt/gravitino-iceberg-rest-server/bin/*.sh \
    && mkdir -p /opt/gravitino-iceberg-rest-server/logs \
    && chown -R 1000:0 /opt/gravitino-iceberg-rest-server \
    && mkdir -p /warehouse \
    && chmod 0777 /warehouse

ENV HADOOP_USER_NAME=root

EXPOSE 9001

USER 1000

CMD ["./bin/gravitino-iceberg-rest-server.sh", "run"]
